    "visualization": {
      "markType": "boxplot",
      "encodings": [
        "x: Customer_Info.age (binned 10-year intervals)",
        "y: Status_Analysis.churn_score",
        "color: Customer_Info.gender",
        "size: aggregated count overlay as semi-transparent circle marks"
      ],
      "description": "Box plots showing churn score distribution across age groups (10-year bins) with gender differentiation. Interactive swarm plot overlay shows individual customer density."
    },
    "interactions": [
      {
        "object": "age-group boxes",
        "verb": "click",
        "effect": {
          "description": "Filters subsequent views to selected age bracket and gender",
          "params": [
            {
              "name": "age_gender_filter",
              "select": {
                "type": "interval",
                "encodings": [
                  "x",
                  "color"
                ]
              }
            }
          ]
        }
      }
    ]
  },
