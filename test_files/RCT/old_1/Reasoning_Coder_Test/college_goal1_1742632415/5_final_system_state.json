  "desc": "The database offers a comprehensive view of an educational institution’s academic ecosystem, covering details about courses, departments, enrollment, faculty, students, and related administrative information.",
  "goal": "Examine enrollment numbers and distribution across various courses, identify popular courses versus those with low enrollment, and explore potential factors influencing these trends.",
  "id": "college_goal1_1742632415",
  "name": "Visual Analytics System college_goal1_1742632415",
  "plan": {
    "graph": [
      {
        "from": 1,
        "to": 2
      },
      {
        "from": 1,
        "to": 3
      }
    ],
    "path": "The user starts with View 1's enrollment overview, identifies extreme courses through color coding and sorting. Course selections propagate to View 2 showing departmental/divisional patterns and View 3 analyzing grade relationships. Brushing in View 3 enables focused analysis of high-enrollment/high-performance courses.",
    "views": [
      {
        "components": "Search box for course names",
        "fields": [
          "Enrolled_in.CID",
          "Course.CName",
          "Enrolled_in.StuID"
        ],
        "id": 1,
        "interactions": [
          {
            "effect": {
              "description": "Selects individual courses for detailed analysis",
              "params": [
                {
                  "name": "selected_course",
                  "select": {
                    "encodings": [
                      "x"
                    ],
                    "type": "point"
                  }
                }
              ]
            },
            "object": "bar chart",
            "verb": "click"
          }
        ],
        "level": "overview",
        "task": [
          1
        ],
        "visualization": {
          "description": "Horizontal bar chart showing enrollment counts per course, with color highlighting for extreme values",
          "encodings": [
            "x-axis: Course.CID (nominal, sorted by enrollment count)",
            "y-axis: COUNT(Enrolled_in.StuID) (quantitative)",
            "color: highlight top 10% and bottom 10% enrollment using conditional encoding"
          ],
          "markType": "bar"
        }
      },
      {
        "components": "Department search filter",
        "fields": [
          "Enrolled_in.CID",
          "Course.DNO",
          "Department.Division",
          "Department.DName"
        ],
        "id": 2,
        "interactions": [
          {
            "effect": {
              "description": "Shows tooltip with exact enrollment numbers and department details"
            },
            "object": "bar chart",
            "verb": "hover"
          }
        ],
        "level": "exploration",
        "task": [
          2
        ],
        "usingParams": [
          "selected_course"
        ],
        "visualization": {
          "description": "Faceted horizontal bar charts showing enrollment distribution across divisions/departments",
          "encodings": [
            "row: Department.Division",
            "x-axis: COUNT(Enrolled_in.StuID)",
            "y-axis: Department.DName (sorted descending by enrollment)",
            "color: Department.Division"
          ],
          "markType": "bar"
        }
      },
      {
        "fields": [
          "Enrolled_in.CID",
          "Gradeconversion.gradepoint",
          "Course.Credits"
        ],
        "id": 3,
        "interactions": [
          {
            "effect": {
              "description": "Highlight courses in specific enrollment/grade ranges",
              "params": [
                {
                  "name": "grade_enrollment_brush",
                  "select": {
                    "encodings": [
                      "x",
                      "y"
                    ],
                    "type": "interval"
                  }
                }
              ]
            },
            "object": "chart",
            "verb": "interval select"
          }
        ],
        "level": "exploration",
        "task": [
          3
        ],
        "usingParams": [
          "selected_course"
