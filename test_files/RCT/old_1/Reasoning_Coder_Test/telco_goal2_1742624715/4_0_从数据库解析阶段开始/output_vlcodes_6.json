{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "columns": 2,
  "concat": [
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_overview.csv"
      },
      "description": "Overview View",
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "contract",
          "type": "nominal",
          "title": "Contract Type"
        },
        "y": {
          "aggregate": "mean",
          "field": "churn_value",
          "type": "quantitative",
          "title": "Churn Rate"
        },
        "color": {
          "field": "internet_type",
          "type": "nominal",
          "title": "Internet Type"
        },
        "opacity": {
          "value": 0.7
        }
      },
      "params": [
        {
          "name": "service_config",
          "select": {
            "type": "point",
            "encodings": [
              "x",
              "color"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration 1 View",
      "data": {
        "url": "http://localhost:8888/vw_exploration_2.csv"
      },
      "mark": "circle",
      "encoding": {
        "x": {
          "field": "churn_score",
          "type": "quantitative",
          "title": "Churn Score"
        },
        "y": {
          "field": "cltv",
          "type": "quantitative",
          "title": "CLTV"
        },
        "color": {
          "field": "satisfaction_score",
          "type": "quantitative",
          "title": "Satisfaction Score"
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/vw_overview.csv"
            },
            "key": "customer_id",
            "fields": [
              "contract"
            ]
          }
        },
        {
          "filter": {
            "param": "service_config"
          }
        },
        {
          "sample": 150
        }
      ],
      "params": [
        {
          "name": "risk_cluster",
          "select": {
            "type": "interval",
            "encodings": [
              "x",
              "y"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration 2 View",
      "data": {
        "url": "http://localhost:8888/vw_exploration_3.csv"
      },
      "mark": "line",
      "encoding": {
        "x": {
          "field": "tenure",
          "type": "quantitative",
          "title": "Tenure"
        },
        "y": {
          "agggregate": "mean",
          "field": "cltv",
          "type": "quantitative",
          "title": "Average CLTV"
        },
        "color": {
          "field": "churn_category",
          "type": "nominal",
          "title": "Churn Category"
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/vw_overview.csv"
            },
            "key": "customer_id",
            "fields": [
              "contract"
            ]
          }
        },
        {
          "filter": {
            "param": "service_config"
          }
        },
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/vw_exploration_2.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_score"
            ]
          }
        },
        {
          "filter": {
            "param": "risk_cluster"
          }
        }
      ]
    },
    {
      "description": "Detail View",
      "data": {
        "url": "http://localhost:8888/vw_detail_4.csv"
      },
      "mark": "rect",
      "encoding": {
        "row": {
          "bin": true,
          "field": "age",
          "type": "quantitative",
          "title": "Age Bins"
        },
        "column": {
          "bin": true,
          "field": "number_of_dependents",
          "type": "quantitative",
          "title": "Dependents Bins"
        },
        "color": {
          "aggregate": "mean",
          "field": "satisfaction_score",
          "type": "quantitative",
          "title": "Average Satisfaction Score"
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/vw_exploration_2.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_score"
            ]
          }
        },
        {
          "filter": {
            "param": "risk_cluster"
          }
        }
      ],
      "params": [
        {
          "name": "service_config",
          "select": {
            "type": "point",
            "encodings": [
              "x",
              "color"
            ]
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "description": "Insight View",
      "data": {
        "url": "http://localhost:8888/vw_insight_5.csv"
      },
      "mark": "point",
      "encoding": {
        "x": {
          "field": "monthly_charges",
          "type": "quantitative",
          "title": "Monthly Charges"
        },
        "y": {
          "field": "total_revenue",
          "type": "quantitative",
          "title": "Total Revenue"
        },
        "size": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Sample Size"
        },
        "color": {
          "aggregate": "mean",
          "field": "churn_value",
          "type": "quantitative",
          "title": "Average Churn Value"
        }
      },
      "params": [
        {
          "name": "service_config",
          "select": {
            "type": "point",
            "encodings": [
              "x",
              "color"
            ]
          }
        }
      ]
    }
  ]
}