              "under_30"
            ]
          }
        },
        {
          "filter": {
            "param": "customer_select"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/view_3_intermediate.csv"
      },
      "description": "View 3 (Detail)",
      "mark": "rect",
      "encoding": {
        "x": {
          "field": "contract",
