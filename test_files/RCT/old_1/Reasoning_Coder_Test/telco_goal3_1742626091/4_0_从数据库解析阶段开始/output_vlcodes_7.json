            "fields": [
              "churn_value"
            ]
          }
        },
        {
          "filter": {
            "param": "service_age_filter"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/view_4_intermediate.csv"
      },
      "description": "View 4 (Insight)",
      "mark": "arc",
      "encoding": {
        "theta": {
