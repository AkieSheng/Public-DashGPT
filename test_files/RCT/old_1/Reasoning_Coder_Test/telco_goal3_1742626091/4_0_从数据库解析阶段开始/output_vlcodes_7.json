          "title": "Churn Rate (%)"
        }
      },
      "params": [
        {
          "name": "customer_select",
          "select": {
            "type": "point",
            "encodings": [
              "color"
            ]
          }
        }
      ],
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/view_1_intermediate.csv"
