      },
      "params": [
        {
          "name": "customer_select",
          "select": {
            "type": "point",
            "encodings": [
              "x",
              "y"
            ]
          }
        }
      ],
      "transform": [
        {
          "filter": {
            "param": "metric_filter"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/view_2_intermediate.csv"
      },
