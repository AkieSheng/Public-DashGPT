  "sqls": [
    {
      "SQL": "CREATE VIEW view_1 AS SELECT t1.District, t1.Soil Type, t1.Organic Matter (%), t2.Yield (quintals) FROM soil_analysis_data AS t1 JOIN crop_production_data AS t2 ON t1.District = t2.District",
      "corrView": 1,
      "fk": [],
      "name": "view_1",
      "pk": "District"
    },
    {
      "SQL": "CREATE VIEW view_2 AS SELECT t1.*, t3.Nitrogen Content (kg/ha), t3.Phosphorus Content (kg/ha), t3.Potassium Content (kg/ha) FROM view_1 AS t1 JOIN water_usage_data AS t2 ON t1.District = t2.District JOIN soil_analysis_data AS t3 ON t1.District = t3.District",
      "corrView": 2,
      "fk": [
        {
          "key": "District",
          "table": "view_1"
        }
      ],
      "name": "view_2",
      "pk": "District"
    },
    {
      "SQL": "CREATE VIEW view_3 AS SELECT t1.*, t4.PH Level, t4 Organic Matter (%), t4.Soil Type FROM view_2 AS t1 JOIN soil_analysis_data AS t2 ON t1.District = t2.District JOIN crop_production_data AS t3 ON t1.District = t3.District JOIN soil_analysis_data AS t4 ON t1.District = t4.District",
      "corrView": 3,
      "fk": [
        {
          "key": "District",
          "table": "view_2"
        }
      ],
      "name": "view_3",
      "pk": "District"
    }
  ],
