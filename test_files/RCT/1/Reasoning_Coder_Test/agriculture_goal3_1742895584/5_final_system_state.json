  "sqls": [
    {
      "SQL": "CREATE VIEW temp_view_1 AS SELECT crop_production_data.District, AVG(crop_production_data.Yield (quintals)) AS avg_yield FROM crop_production_data GROUP BY crop_production_data.District",
      "corrView": 1,
      "fk": [],
      "id": 1,
      "name": "temp_view_1",
      "pk": "District"
    },
    {
      "SQL": "CREATE VIEW temp_view_2 AS SELECT soil_analysis_data.District, soil_analysis_data.Organic Matter (%), soil_analysis_data.Soil Type, crop_production_data.Yield (quintals) FROM soil_analysis_data JOIN crop_production_data ON soil_analysis_data.District = crop_production_data.District",
      "corrView": 2,
      "fk": [
        {
          "key": "District",
          "table": "temp_view_1"
        }
      ],
      "id": 2,
      "name": "temp_view_2",
      "pk": "District"
    },
    {
      "SQL": "CREATE VIEW temp_view_3 AS SELECT soil_analysis_data.Soil Type, soil_analysis_data.Nitrogen Content (kg/ha), soil_analysis_data.Phosphorus Content (kg/ha), soil_analysis_data.Potassium Content (kg/ha) FROM soil_analysis_data",
      "corrView": 3,
      "fk": [
