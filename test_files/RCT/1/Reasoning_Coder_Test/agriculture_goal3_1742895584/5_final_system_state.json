    },
    {
      "SQL": "CREATE VIEW temp_view_4 AS SELECT soil_analysis_data.Soil Type, crop_production_data.Crop, AVG(crop_production_data.Yield (quintals)) AS avg_yield FROM soil_analysis_data JOIN crop_production_data ON soil_analysis_data.District = crop_production_data.District GROUP BY soil_analysis_data.Soil Type, crop_production_data.Crop",
