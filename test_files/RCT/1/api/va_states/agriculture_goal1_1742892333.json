  "sqls": [
    {
      "id": 1,
      "name": "view_1",
      "SQL": "CREATE VIEW view_1 AS SELECT water_usage_data.Irrigation, water_usage_data.Water_Consumption, crop_production_data.Yield, crop_production_data.Crop FROM water_usage_data JOIN crop_production_data ON water_usage_data.District = crop_production_data.District AND water_usage_data.Crop = crop_production_data.Crop;",
      "corrView": "1",
      "pk": "Irrigation, District, Crop",
      "fk": []
    },
    {
      "id": 2,
      "name": "view_2",
      "SQL": "CREATE VIEW view_2 AS SELECT water_usage_data.District, water_usage_data.Water_Consumption, crop_production_data.Yield, water_usage_data.Water_Availability, crop_production_data.Crop FROM water_usage_data JOIN crop_production_data ON water_usage_data.District = crop_production_data.District AND water_usage_data.Crop = crop_production_data.Crop;",
      "corrView": "2",
      "pk": "District, Crop",
      "fk": [
        "view_1"
      ]
    },
    {
      "id": 3,
      "name": "view_3",
      "SQL": "CREATE VIEW view_3 AS SELECT soil_analysis_data.Soil_Type, soil_analysis_data.pH_Level, soil_analysis_data.Organic_Matter, water_usage_data.Irrigation FROM soil_analysis_data JOIN water_usage_data ON soil_analysis_data.District = water_usage_data.District;",
      "corrView": "3",
      "pk": "Soil_Type, District, Irrigation",
      "fk": []
