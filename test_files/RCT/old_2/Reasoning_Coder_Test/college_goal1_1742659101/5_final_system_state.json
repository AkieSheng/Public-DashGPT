  "desc": "The database offers a comprehensive view of an educational institution’s academic ecosystem, covering details about courses, departments, enrollment, faculty, students, and related administrative information.",
  "goal": "Examine enrollment numbers and distribution across various courses, identify popular courses versus those with low enrollment, and explore potential factors influencing these trends.",
  "id": "college_goal1_1742659101",
  "name": "Visual Analytics System college_goal1_1742659101",
  "plan": {
    "graph": [
      {
        "from": 1,
        "to": 2
      },
      {
        "from": 1,
        "to": 3
      }
    ],
    "path": "The user starts with View 1 (Overview) to observe enrollment distribution across courses and divisions. Selecting high/low enrollment courses triggers Views 2-3 (Exploration). View 2 reveals temporal patterns for selected courses while View 3 compares age distributions between divisions, enabling identification of demographic influences.",
    "views": [
      {
        "fields": [
          "Enrolled_in.CID",
          "Course.CName",
          "Department.Division"
        ],
        "id": 1,
        "interactions": [
          {
            "effect": {
              "description": "Select courses to filter downstream views",
              "params": [
                {
                  "name": "selected_courses",
                  "select": {
                    "encodings": [
                      "y"
                    ],
                    "type": "point"
                  }
                }
              ]
            },
            "object": "chart",
            "verb": "click"
          }
        ],
        "level": "overview",
        "task": [
          1,
          2
        ],
        "visualization": {
          "description": "Horizontal bar chart showing course enrollment distribution colored by academic division. Courses sorted by enrollment count with top/bottom extremes visually prominent.",
          "encodings": [
            "x: count(Enrolled_in.CID) aggregated by Course.CName",
            "y: Course.CName sorted by enrollment count",
            "color: Department.Division (nominal scale: AS/EN)",
            "tooltip: count(Enrolled_in.CID), Department.DName"
          ],
          "markType": "bar"
        }
      },
      {
        "fields": [
          "Course.Hours",
          "Course.Days",
          "Enrolled_in.CID"
        ],
        "id": 2,
        "interactions": [
          {
            "effect": {
              "description": "Highlight temporal patterns",
              "params": []
            },
            "object": "chart",
            "verb": "hover"
          }
        ],
        "level": "exploration",
        "task": [
          3
        ],
        "usingParams": [
          "selected_courses"
        ],
        "visualization": {
          "description": "Stacked bar chart showing enrollment distribution across temporal patterns (days/hours combinations)",
          "encodings": [
            "x: Hours (binned) combined with Days (ordinal)",
            "y: count(Enrolled_in.CID)",
            "color: Days (nominal scale)",
            "tooltip: Time slot breakdown"
          ],
          "markType": "bar"
        }
      },
      {
        "components": "Division toggle switch",
        "fields": [
          "Student.Age",
          "Department.Division"
        ],
        "id": 3,
        "level": "exploration",
        "task": [
          4
        ],
        "usingParams": [
          "selected_courses"
        ],
        "visualization": {
          "description": "Box plots with jittered points showing age distribution per academic division",
          "encodings": [
            "x: Department.Division (AS/EN)",
