  "desc": "The database offers a comprehensive view of an educational institution’s academic ecosystem, covering details about courses, departments, enrollment, faculty, students, and related administrative information.",
  "goal": "Conduct a comprehensive analysis of students’ major subjects, minor selections, and organizational memberships, thereby exploring overall patterns and potential correlations between academic profiles and extracurricular engagement.",
  "id": "college_goal3_1742660964",
  "name": "Visual Analytics System college_goal3_1742660964",
  "plan": {
    "graph": {
      "notes": "Critical compatibility fixes: Network/map visualizations replaced with composable matrix and conventional charts. Cluster analysis now uses pairwise attribute comparisons instead of high-dimensional parallel coordinates"
    },
    "path": "The user begins with View 1 at the Overview level to understand major enrollment patterns across divisions. Selecting departments of interest triggers updates in View 2 (major-minor correlations via heatmap) and View 3 (gender-based performance analysis). A simultaneous update to View 4 reveals organizational relationships through advisor networks. Brushing in View 2/3 further filters student cohorts in connected views.",
    "views": [
      {
        "fields": [
          "Student.Major",
          "Department.DNO",
          "Department.DName",
          "Department.Division"
        ],
        "id": 1,
        "interactions": [
          {
            "effect": {
              "description": "Select single/multiple departments to filter subsequent views",
              "params": [
                {
                  "name": "selected_dept",
                  "select": {
                    "encodings": [
                      "y"
                    ],
                    "type": "point"
                  }
                }
              ]
            },
            "object": "chart",
            "verb": "click"
          }
        ],
        "level": "overview",
        "task": [
          1
        ],
        "visualization": {
          "description": "Horizontal bar chart showing student distribution across academic departments, colored by institutional division (AS/EN)",
          "encodings": [
            "x: aggregate count of Student.Major (quantitative)",
            "y: Department.DName (nominal) sorted by enrollment count",
            "color: Division (nominal)"
          ],
          "markType": "bar"
        }
      },
      {
        "components": "Department name labels for both axes via join on DNO",
        "fields": [
          "Student.Major",
          "Minor_in.DNO",
          "Department.DName"
        ],
        "id": 2,
        "interactions": [
          {
            "effect": {
              "description": "Show tooltip with exact minor pair count and department names"
            },
            "object": "chart",
            "verb": "hover"
          }
        ],
        "level": "exploration",
        "task": [
          2
        ],
        "usingParams": [
          "selected_dept"
        ],
        "visualization": {
          "description": "Heatmap showing major-minor combinations with color intensity indicating frequency",
          "encodings": [
            "x: Minor_in.DNO (nominal) mapped to DName via join",
            "y: Student.Major (nominal) mapped to DName via join",
            "color: aggregate count (quantitative)"
          ],
          "markType": "rect"
        }
      },
      {
        "fields": [
          "Student.Major",
          "Enrolled_in.Grade",
          "Gradeconversion.gradepoint",
          "Student.Sex"
        ],
        "id": 3,
        "interactions": [
          {
            "effect": {
              "description": "Filter transaction records in detail view",
              "params": [
                {
                  "name": "selected_performance",
                  "select": {
                    "encodings": [
                      "y"
                    ],
                    "type": "interval"
                  }
                }
              ]
            },
            "object": "chart",
            "verb": "click"
          }
        ],
        "level": "exploration",
        "task": [
          3
        ],
        "usingParams": [
          "selected_dept"
        ],
        "visualization": {
          "description": "Grouped bar chart showing gender-based academic performance per department with error bars",
          "encodings": [
            "x: Department.DName (nominal)",
            "y: average gradepoint (quantitative)",
            "color: Sex (nominal)",
            "column: Sex (nominal)"
          ],
          "markType": "bar"
        }
      },
      {
        "components": "Node size legend, edge thickness scale",
        "fields": [
