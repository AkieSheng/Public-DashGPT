  "requirements": {
    "data": [
      {
        "id": "D1",
        "reason": "Core analysis requires direct linkage between irrigation methods/water metrics and yield data - soil parameters are secondary for this specific goal",
        "requirement": "Join water_usage_data and crop_production_data via District+Crop instead of soil_analysis_data"
      },
      {
        "id": "DX",
        "reason": "Seasonal alignment is critical for comparing water usage patterns with agricultural cycles",
        "requirement": "Retain seasonal filters from crop_production_data (Kharif/Rabi) instead of Date columns"
      }
    ],
    "interaction": [
      {
        "id": "I4",
        "reason": "Visitors need to analyze trends within specific irrigation methods",
        "requirement": "Enable users to filter data by灌溉方法 (Irrigation Method) to observe water consumption and yield trends"
      },
      {
        "id": "I5",
        "reason": "Users need to observe season-based variations in water consumption and yield",
        "requirement": "Allow filtering by 季节 (Season) to compare water usage patterns by specific agricultural cycles"
      }
    ],
    "visualization": [
      {
        "id": "V4",
        "reason": "Essential to visualize central relationship between water efficiency and agricultural output",
        "requirement": "Add scatter plots comparing Water Consumption vs Yield grouped by Irrigation Method"
      }
    ]
  },
  "sqls": [
    {
      "SQL": "CREATE VIEW view_1 AS SELECT water_usage_data.Irrigation_Method, water_usage_data.Water_Consumption_liters_hectare, AVG(crop_production_data.Yield_quintals) AS Avg_Yield_quintals FROM water_usage_data JOIN crop_production_data ON water_usage_data.Crop = crop_production_data.Crop AND water_usage_data.District = crop_production_data.District GROUP BY water_usage_data.Irrigation_Method, water_usage_data.Water_Consumption_liters_hectare",
      "corrView": "1",
      "fk": [],
      "name": "view_1",
      "pk": "Irrigation_Method|Water_Consumption_liters_hectare"
    },
    {
      "SQL": "CREATE VIEW view_2 AS SELECT water_usage_data.Crop, water_usage_data.Water_Consumption_liters_hectare, MAX(crop_production_data.Yield_quintals) AS Max_Yield_quintals FROM water_usage_data JOIN crop_production_data ON water_usage_data.Crop = crop_production_data.Crop AND water_usage_data.District = crop_production_data.District GROUP BY water_usage_data.Crop, water_usage_data.Water_Consumption_liters_hectare",
      "corrView": "2",
      "fk": [],
      "name": "view_2",
      "pk": "Crop|Water_Consumption_liters_hectare"
    },
    {
      "SQL": "CREATE VIEW view_3 AS SELECT soil_analysis_data.Soil_Type, soil_analysis_data.Organic_Matter, water_usage_data.District, MAX(crop_price_data.Price_INR_quintal) AS Avg_Price_INR_quintal FROM soil_analysis_data JOIN water_usage_data ON soil_analysis_data.District = water_usage_data.District JOIN crop_price_data ON soil_analysis_data.District = crop_price_data.District AND water_usage_data.Crop = crop_price_data.Crop GROUP BY soil_analysis_data.Soil_Type, soil_analysis_data.Organic_Matter, water_usage_data.District",
      "corrView": "3",
      "fk": [],
      "name": "view_3",
      "pk": "Soil_Type|Organic_Matter|District"
    }
  ],
