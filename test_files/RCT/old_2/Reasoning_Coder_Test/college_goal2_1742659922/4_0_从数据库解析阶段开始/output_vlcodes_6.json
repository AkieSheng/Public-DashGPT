          },
          "y": {
            "field": "Rank",
            "type": "nominal",
            "axis": null
          }
        }
      },
      {
        "title": "Faculty Name",
        "mark": "text",
        "encoding": {
          "text": {
            "field": "Lname",
            "type": "nominal"
          },
          "y": {
            "field": "Rank",
            "type": "nominal",
            "axis": null
          }
        }
      },
      {
        "title": "Faculty Rank",
        "mark": "text",
        "encoding": {
          "text": {
            "field": "Rank",
            "type": "nominal"
          },
          "y": {
            "field": "Rank",
            "type": "nominal",
            "axis": null
          }
        }
      },
      {
        "title": "Appointment Type",
        "mark": "text",
        "encoding": {
          "text": {
            "field": "Appt_Type",
