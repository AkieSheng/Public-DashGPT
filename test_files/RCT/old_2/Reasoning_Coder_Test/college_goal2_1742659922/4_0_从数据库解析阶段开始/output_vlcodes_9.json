{
  "description": "Visual Analytics System for Faculty Distribution Analysis",
  "height": 200,
  "width": 200,
  "data": {
    "url": "http://localhost:8888/Department_Member.csv"
  },
  "params": [
    {
      "name": "dept_filter",
      "select": {
        "type": "point",
        "encodings": [
          "x"
        ]
      }
    },
    {
      "name": "bubble_brush",
      "select": {
        "type": "interval",
        "encodings": [
          "x",
          "y"
        ]
      }
    }
  ],
  "transform": [
    {
      "lookup": "DNO",
      "from": {
        "data": {
          "url": "http://localhost:8888/Department.csv"
        },
        "key": "DNO",
        "fields": [
          "DName"
        ]
      }
    },
    {
      "filter": {
        "param": "dept_filter"
      }
    },
    {
      "lookup": "FacID",
      "from": {
        "data": {
          "url": "http://localhost:8888/Employee_Courses.csv"
        },
        "key": "FacID",
        "fields": [
          "DName",
          "Rank"
        ]
      }
    },
    {
      "filter": {
        "param": "bubble_brush"
      }
    }
  ],
  "concat": [
    {
      "description": "Overview View",
      "data": {
        "url": "http://localhost:8888/Department_Member.csv"
      },
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "DName",
          "type": "nominal",
          "title": "Department"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Faculty Count"
        },
        "color": {
          "field": "DName",
          "type": "nominal",
          "title": "Department"
        }
      },
      "params": [
        {
          "name": "dept_filter",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration View 1 - Course Count by Department",
      "data": {
        "url": "http://localhost:8888/Employee_Courses.csv"
      },
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "DName",
          "type": "nominal",
          "title": "Department"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Course Count"
        },
        "color": {
          "field": "Rank",
          "type": "nominal",
          "title": "Rank"
        }
      },
      "transform": [
        {
          "lookup": "DNO",
          "from": {
            "data": {
              "url": "http://localhost:8888/Department.csv"
            },
            "key": "DNO",
            "fields": [
              "DName"
            ]
          }
        }
      ],
      "params": [
        {
          "name": "dept_filter",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration View 2 - Gender Distribution by Rank",
      "data": {
        "url": "http://localhost:8888/Employee_Details.csv"
      },
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "Rank",
          "type": "nominal",
          "title": "Rank"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Count"
        },
        "color": {
          "field": "Sex",
          "type": "nominal",
          "title": "Gender"
        },
        "column": {
          "field": "DName",
          "type": "nominal",
          "title": "Department"
        }
      },
      "transform": [
        {
          "lookup": "FacID",
          "from": {
            "data": {
              "url": "http://localhost:8888/Faculty.csv"
            },
            "key": "FacID",
            "fields": [
              "DName",
              "Rank"
            ]
          }
        }
      ],
      "params": [
        {
          "name": "dept_filter",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration View 3 - Bubble Chart",
      "data": {
        "url": "http://localhost:8888/Employee_Courses.csv"
      },
      "mark": "circle",
      "encoding": {
        "x": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Faculty Count"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Course Count"
        },
        "size": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Course Count"
        },
        "color": {
          "field": "DName",
          "type": "nominal",
          "title": "Department"
        }
      },
      "params": [
        {
          "name": "bubble_brush",
          "select": {
            "type": "interval",
            "encodings": [
              "x",
              "y"
            ]
          }
        }
      ]
    },
    {
      "description": "Detail View",
      "data": {
        "url": "http://localhost:8888/Employee_Details.csv"
      },
      "mark": "table",
      "encoding": {},
      "transform": [
        {
          "lookup": "FacID",
          "from": {
            "data": {
              "url": "http://localhost:8888/Faculty.csv"
            },
            "key": "FacID",
            "fields": [
              "FacID",
              "Lname",
              "Rank",
              "DName"
            ]
          }
        },
        {
          "filter": {
            "param": "bubble_brush"
          }
        }
      ],
      "params": [
        {
          "name": "bubble_brush",
          "select": {
            "type": "interval",
            "encodings": [
              "x",
              "y"
            ]
          }
        }
      ]
    }
  ]
}