{
  "Overview_Faculty_Count": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
      "url": "http://localhost:8888/Overview_Faculty_Count.csv"
    },
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "DName",
        "type": "nominal",
        "title": "Department"
      },
      "y": {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of Faculty Members"
      },
      "color": {
        "field": "DName",
        "type": "nominal",
        "title": "Department"
      }
    }
  },
  "Faculty_Course_Count": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
      "url": "http://localhost:8888/Faculty_Course_Count.csv"
    },
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "DName",
        "type": "nominal",
        "title": "Department"
      },
      "y": {
        "aggregate": "sum",
        "field": "CourseCount",
        "type": "quantitative",
        "title": "Number of Courses"
      },
      "color": {
        "field": "Rank",
        "type": "nominal",
        "title": "Rank"
      }
    },
    "transform": [
      {
        "lookup": "DName",
        "from": {
          "data": {
            "url": "http://localhost:8888/Department_Member.csv"
          },
          "key": "DName",
          "fields": [
            "DName"
          ]
        }
      }
    ]
  },
  "Faculty_Gender_By_Rank": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
      "url": "http://localhost:8888/Faculty_Gender_By_Rank.csv"
    },
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "Rank",
        "type": "nominal",
        "title": "Rank"
      },
      "y": {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of Faculty Members"
      },
      "color": {
        "field": "Sex",
        "type": "nominal",
        "title": "Gender"
      }
    },
    "transform": [
      {
        "lookup": "DName",
        "from": {
          "data": {
            "url": "http://localhost:8888/Department_Member.csv"
          },
          "key": "DName",
          "fields": [
            "DName"
          ]
        }
      }
    ]
  },
  "Faculty_Course_Faculty_Count_Overview": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
      "url": "http://localhost:8888/Faculty_Course_Faculty_Count_Overview.csv"
    },
    "mark": "circle",
    "encoding": {
      "x": {
        "field": "FacultyCount",
        "type": "quantitative",
        "title": "Number of Faculty Members"
      },
      "y": {
        "field": "CourseCount",
        "type": "quantitative",
        "title": "Number of Courses"
      },
      "size": {
        "field": "CourseCount",
        "type": "quantitative",
        "title": "Number of Courses"
      },
      "color": {
        "field": "DName",
        "type": "nominal",
        "title": "Department"
      }
    }
  },
  "Faculty_Details_Overview": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "data": {
      "url": "http://localhost:8888/Faculty_Details_Overview.csv"
    },
    "title": "Faculty Details",
    "transform": [
      {
        "lookup": "FacID",
        "from": {
          "data": {
            "url": "http://localhost:8888/Department_Member.csv"
          },
          "key": "FacID",
          "fields": [
            "FacID"
          ]
        }
      }
    ]
  }
}