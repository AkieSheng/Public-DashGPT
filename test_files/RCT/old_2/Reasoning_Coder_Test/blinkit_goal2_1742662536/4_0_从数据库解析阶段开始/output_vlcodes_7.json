{
  "overview-view": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Overview View",
    "width": 600,
    "height": 400,
    "data": {
      "url": "http://localhost:8888/customer_orders_view.csv"
    },
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "axis": {
          "titleColor": "black"
        }
      },
      "y": {
        "field": "total_orders",
        "type": "quantitative",
        "title": "Total Orders",
        "axis": {
          "titleColor": "black"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "black"
        }
      },
      "opacity": {
        "value": 0.7
      }
    },
    "params": [
      {
        "name": "selected_segment",
        "select": {
          "type": "point",
          "encodings": [
            "y"
          ]
        }
      }
    ]
  },
  "exploration-view": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Exploration View",
    "width": 600,
    "height": 400,
    "data": {
      "url": "http://localhost:8888/product_co_occurrence_view.csv"
    },
    "mark": "rect",
    "encoding": {
      "x": {
        "field": "product_a",
        "type": "nominal",
        "title": "Product A",
        "axis": {
          "titleColor": "black"
        }
      },
      "y": {
        "field": "product_b",
        "type": "nominal",
        "title": "Product B",
        "axis": {
          "titleColor": "black"
        }
      },
      "size": {
        "field": "co_occurrence_count",
        "type": "quantitative",
        "title": "Co-Occurrence Count",
        "axis": {
          "titleColor": "black"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "black"
        }
      }
    },
    "transform": [
      {
        "lookup": "order_id",
        "from": {
          "data": {
            "url": "http://localhost:8888/customer_orders_view.csv"
          },
          "key": "order_id",
          "fields": [
            "customer_segment"
          ]
        }
      },
      {
        "filter": {
          "param": "selected_segment"
        }
      }
    ],
    "params": [
      {
        "name": "selected_segment",
        "select": {
          "type": "point",
          "encodings": [
            "y"
          ]
        }
      }
    ]
  },
  "detail-view": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Detail View",
    "width": 600,
    "height": 400,
    "data": {
      "url": "http://localhost:8888/product_co_occurrence_view.csv"
    },
    "mark": "circles",
    "encoding": {
      "x": {
        "field": "product_a",
        "type": "nominal",
        "title": "Product A",
        "axis": {
          "titleColor": "black"
        }
      },
      "y": {
        "field": "product_b",
        "type": "nominal",
        "title": "Product B",
        "axis": {
          "titleColor": "black"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "black"
        }
      },
      "size": {
        "field": "co_occurrence_count",
        "type": "quantitative",
        "title": "Co-Occurrence Count",
        "axis": {
          "titleColor": "black"
        }
      }
    },
    "transform": [
      {
        "lookup": "order_id",
        "from": {
          "data": {
            "url": "http://localhost:8888/customer_orders_view.csv"
          },
          "key": "order_id",
          "fields": [
            "customer_segment"
          ]
        }
      },
      {
        "filter": {
          "param": "selected_segment"
        }
      }
    ],
    "params": [
      {
        "name": "selected_segment",
        "select": {
          "type": "point",
          "encodings": [
            "y"
          ]
        }
      }
    ]
  }
}