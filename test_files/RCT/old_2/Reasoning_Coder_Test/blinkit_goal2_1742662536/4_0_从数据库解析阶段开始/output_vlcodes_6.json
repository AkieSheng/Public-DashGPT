{
  "V1": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "height": 200,
    "width": 200,
    "description": "View 1: Overview of customer order frequency segmented by customer category",
    "data": {
      "url": "http://localhost:8888/customer_orders_view.csv"
    },
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "total_orders",
        "type": "quantitative",
        "title": "Number of Orders",
        "axis": {
          "titleColor": "blue"
        }
      },
      "y": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "axis": {
          "titleColor": "blue"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "blue",
          "titleFontSize": 14,
          "labelFontSize": 12
        }
      },
      "opacity": {
        "value": 0.3,
        "condition": {
          "param": "selected_segment",
          "value": true
        }
      }
    },
    "params": [
      {
        "name": "selected_segment",
        "select": {
          "type": "point",
          "encodings": [
            "y"
          ]
        }
      }
    ]
  },
  "V2": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "height": 200,
    "width": 200,
    "description": "View 2: Product category frequency analysis highlighted by selected customer segments",
    "data": {
      "url": "http://localhost:8888/category_orders_view.csv"
    },
    "mark": "rect",
    "encoding": {
      "x": {
        "field": "category",
        "type": "nominal",
        "title": "Product Category",
        "axis": {
          "titleColor": "green"
        }
      },
      "y": {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of Orders",
        "axis": {
          "titleColor": "green"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "green",
          "titleFontSize": 14,
          "labelFontSize": 12
        }
      }
    },
    "transform": [
      {
        "filter": {
          "param": "selected_segment"
        }
      }
    ],
    "params": [
      {
        "name": "selected_segment",
        "select": {
          "type": "point",
          "encodings": [
            "y"
          ]
        }
      }
    ]
  },
  "V3": {
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "height": 200,
    "width": 200,
    "description": "View 3: Co-occurrence matrix showing product pairs frequently bought together",
    "data": {
      "url": "http://localhost:8888/product_cooccurrence_view.csv"
    },
    "mark": "circle",
    "encoding": {
      "x": {
        "field": "productA",
        "type": "nominal",
        "title": "Product A",
        "axis": {
          "titleColor": "red"
        }
      },
      "y": {
        "field": "productB",
        "type": "nominal",
        "title": "Product B",
        "axis": {
          "titleColor": "red"
        }
      },
      "size": {
        "field": "cooccurrence_count",
        "type": "quantitative",
        "title": "Co-occurrence Count",
        "scale": {
          "domain": [
            1,
            100
          ],
          "type": "sqrt"
        }
      },
      "color": {
        "field": "customer_segment",
        "type": "nominal",
        "title": "Customer Segment",
        "legend": {
          "titleColor": "red",
          "titleFontSize": 14,
          "labelFontSize": 12
        }
      }
    }
  }
}