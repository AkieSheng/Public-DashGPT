{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "columns": 2,
  "concat": [
    {
      "height": 200,
      "width": 200,
      "description": "View 1: Overview - Bar Chart",
      "data": {
        "url": "http://localhost:8888/temp_view_1.csv"
      },
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender"
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Number of Customers"
        },
        "color": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender"
        },
        "opacity": {
          "value": 0.3,
          "condition": {
            "param": "selectedGender",
            "value": 1
          }
        }
      },
      "params": [
        {
          "name": "selectedGender",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "description": "View 2: Exploration - Scatter Plot",
      "data": {
        "url": "http://localhost:8888/temp_view_1.csv"
      },
      "mark": "circle",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "title": "Age"
        },
        "y": {
          "field": "churn_score",
          "type": "quantitative",
          "title": "Churn Score"
        },
        "color": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender"
        },
        "tooltip": [
          {
            "field": "gender",
            "type": "nominal"
          },
          {
            "field": "age",
            "type": "quantitative"
          },
          {
            "field": "churn_score",
            "type": "quantitative"
          }
        ]
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/temp_view_2.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_label"
            ]
          }
        },
        {
          "filter": {
            "param": "selectedGender"
          }
        },
        {
          "sample": 150
        }
      ],
      "params": [
        {
          "name": "filteredAgeRange",
          "select": {
            "type": "interval",
            "encodings": [
              "x"
            ]
          },
          "bind": "scales"
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "description": "View 3: Exploration - Area Chart",
      "data": {
        "url": "http://localhost:8888/temp_view_1.csv"
      },
      "mark": "area",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "bin": true
        },
        "y": {
          "field": "churn_label",
          "type": "nominal",
          "title": "Churn Status"
        },
        "color": {
          "field": "satisfaction_score",
          "type": "quantitative",
          "title": "Satisfaction Score"
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/temp_view_2.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_label"
            ]
          }
        },
        {
          "filter": {
            "param": "filteredAgeRange"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "description": "View 4: Detail - Pie Chart",
      "data": {
        "url": "http://localhost:8888/temp_view_4.csv"
      },
      "mark": "arc",
      "encoding": {
        "theta": {
          "field": "churn_category",
          "type": "quantitative",
          "aggregate": "count"
        },
        "color": {
          "field": "senior_citizen",
          "type": "nominal",
          "title": "Senior Citizen"
        }
      },
      "transform": []
    },
    {
      "height": 200,
      "width": 200,
      "description": "View 5: Insight - Heatmap",
      "data": {
        "url": "http://localhost:8888/temp_view_1.csv"
      },
      "mark": "rect",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "bin": true
        },
        "y": {
          "field": "city",
          "type": "nominal"
        },
        "color": {
          "field": "churn_label",
          "type": "nominal",
          "title": "Churn Label",
          "scale": {
            "domain": [
              "No",
              "Yes"
            ],
            "range": [
              "#6baed6",
              "#fc4e51"
            ]
          }
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/temp_view_2.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_label"
            ]
          }
        },
        {
          "filter": {
            "param": "filteredAgeRange"
          }
        }
      ]
    }
  ]
}