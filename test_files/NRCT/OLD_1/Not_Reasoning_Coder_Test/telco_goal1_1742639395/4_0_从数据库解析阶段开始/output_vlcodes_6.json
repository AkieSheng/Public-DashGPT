{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Visual Analytics System (VAS) for customer churn analysis",
  "params": [
    {
      "name": "selectedGender",
      "select": {
        "type": "point",
        "encodings": [
          "x"
        ]
      }
    },
    {
      "name": "filteredAgeRange",
      "select": {
        "type": "interval",
        "encodings": [
          "x"
        ]
      }
    }
  ],
  "data": {
    "values": [
      {
        "customer_id": "9995-HOTOH",
        "gender": "Male",
        "age": 25,
        "senior_citizen": "No",
        "partner": "No",
        "dependents": "No",
        "churn_label": "Yes"
      },
      {
        "customer_id": "0002-ORFBO",
        "gender": "Female",
        "age": 55,
        "senior_citizen": "Yes",
        "partner": "Yes",
        "dependents": "No",
        "churn_label": "No"
      },
      {
        "customer_id": "0003-MKNFE",
        "gender": "Male",
        "age": 42,
        "senior_citizen": "No",
        "partner": "No",
        "dependents": "No",
        "churn_label": "Yes"
      },
      {
        "customer_id": "9938-PRCVK",
        "gender": "Female",
        "age": 35,
        "senior_citizen": "No",
        "partner": "Yes",
        "dependents": "Yes",
        "churn_label": "No"
      },
      {
        "customer_id": "9938-TKDGL",
        "gender": "Male",
        "age": 60,
        "senior_citizen": "Yes",
        "partner": "Yes",
        "dependents": "No",
        "churn_label": "Yes"
      }
    ]
  },
  "vconcat": [
    {
      "description": "Overview View",
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender",
          "axis": {
            "titleColor": "blue"
          }
        },
        "y": {
          "aggregate": "count",
          "type": "quantitative",
          "title": "Count of Churned Customers",
          "axis": {
            "titleColor": "blue"
          }
        },
        "color": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender",
          "axis": {
            "titleColor": "blue"
          }
        }
      },
      "params": [
        {
          "name": "selectedGender",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration View",
      "mark": "point",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "title": "Age",
          "axis": {
            "titleColor": "red"
          }
        },
        "y": {
          "field": "churn_score",
          "type": "quantitative",
          "title": "Churn Score",
          "axis": {
            "titleColor": "red"
          }
        },
        "color": {
          "field": "gender",
          "type": "nominal",
          "title": "Gender",
          "axis": {
            "titleColor": "red"
          }
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/Location_Data.csv"
            },
            "key": "customer_id",
            "fields": [
              "city"
            ]
          }
        },
        {
          "filter": {
            "param": "selectedGender"
          }
        }
      ],
      "params": [
        {
          "name": "filteredAgeRange",
          "select": {
            "type": "interval",
            "encodings": [
              "x"
            ]
          }
        }
      ]
    },
    {
      "description": "Exploration View",
      "mark": "area",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "title": "Age",
          "bin": {
            "maxbins": 10
          },
          "axis": {
            "titleColor": "green"
          }
        },
        "y": {
          "field": "churn_label",
          "type": "nominal",
          "title": "Churn Label",
          "axis": {
            "titleColor": "green"
          }
        },
        "color": {
          "field": "satisfaction_score",
          "type": "quantitative",
          "title": "Satisfaction Score",
          "axis": {
            "titleColor": "green"
          }
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/Status_Analysis.csv"
            },
            "key": "customer_id",
            "fields": [
              "churn_score",
              "satisfaction_score"
            ]
          }
        },
        {
          "filter": {
            "param": "filteredAgeRange"
          }
        }
      ]
    },
    {
      "description": "Detail View",
      "mark": "arc",
      "encoding": {
        "theta": {
          "field": "churn_category",
          "type": "quantitative",
          "aggregate": "count",
          "axis": {
            "titleColor": "purple"
          }
        },
        "color": {
          "field": "senior_citizen",
          "type": "nominal",
          "title": "Senior Citizen",
          "axis": {
            "titleColor": "purple"
          }
        }
      }
    },
    {
      "description": "Insight View",
      "mark": "rect",
      "encoding": {
        "x": {
          "field": "age",
          "type": "quantitative",
          "title": "Age",
          "bin": {
            "maxbins": 10
          },
          "axis": {
            "titleColor": "orange"
          }
        },
        "y": {
          "field": "city",
          "type": "nominal",
          "title": "City",
          "axis": {
            "titleColor": "orange"
          }
        },
        "color": {
          "field": "churn_label",
          "type": "quantitative",
          "aggregate": "mean",
          "axis": {
            "titleColor": "orange"
          }
        }
      },
      "transform": [
        {
          "lookup": "customer_id",
          "from": {
            "data": {
              "url": "http://localhost:8888/Location_Data.csv"
            },
            "key": "customer_id",
            "fields": [
              "city"
            ]
          }
        },
        {
          "filter": {
            "param": "filteredAgeRange"
          }
        }
      ]
    }
  ],
  "resolve": {
    "scale": {
      "color": "independent"
    }
  }
}