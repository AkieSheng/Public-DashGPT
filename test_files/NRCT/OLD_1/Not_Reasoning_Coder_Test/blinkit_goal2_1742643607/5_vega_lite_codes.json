        "type": "quantitative"
      }
    },
    "mark": "line",
    "selection": {
      "interval": {
        "encodings": [
          "x",
          "y"
        ],
        "type": "interval"
      }
    }
  },
  "v6_scatter_plot": {
    "encoding": {
      "color": {
        "field": "customer_segment",
