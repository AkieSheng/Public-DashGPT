      },
      "x": {
        "field": "secondary_product_id",
        "type": "nominal"
      },
      "y": {
        "field": "co_occurrence",
        "type": "quantitative"
      }
    },
    "mark": "bar"
  },
  "v2_heat_map": {
    "encoding": {
      "color": {
        "field": "purchase_frequency",
        "type": "quantitative"
      },
      "x": {
        "field": "customer_segment",
        "type": "nominal"
      },
      "y": {
        "field": "area",
        "type": "nominal"
      }
    },
    "mark": "rect"
  },
  "v3_scatter_plot": {
    "encoding": {
      "color": {
        "field": "customer_segment",
        "type": "nominal"
      },
      "tooltip": [
