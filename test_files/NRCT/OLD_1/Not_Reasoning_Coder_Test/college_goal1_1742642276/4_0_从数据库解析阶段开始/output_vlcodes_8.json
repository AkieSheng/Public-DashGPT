{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "columns": 2,
  "concat": [
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_enrolled_courses.csv"
      },
      "description": "Overview: Enrollment Distribution by Course",
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "CID",
          "type": "nominal",
          "title": "Course ID"
        },
        "y": {
          "field": "TotalEnrollment",
          "type": "quantitative",
          "title": "Total Enrollment"
        },
        "color": {
          "condition": {
            "test": "datum.TotalEnrollment > quantiles('TotalEnrollment', 0.90)",
            "value": "red"
          },
          "value": "blue"
        }
      },
      "params": [
        {
          "name": "selectedCourses",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ],
      "transform": [
        {
          "filter": {
            "param": "selectedCourses"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_enrollment_heatmap.csv"
      },
      "description": "Exploration: Enrollments by Grade",
      "mark": "rect",
      "encoding": {
        "x": {
          "field": "CID",
          "type": "nominal",
          "title": "Course ID"
        },
        "y": {
          "field": "gradepoint",
          "type": "quantitative",
          "title": "Grade Points"
        },
        "color": {
          "field": "AvgGradePoints",
          "type": "quantitative",
          "title": "Average Grade Points"
        }
      },
      "params": [
        {
          "name": "hoveredCourse",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ],
      "transform": [
        {
          "filter": {
            "param": "hoveredCourse"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_department_enrollment.csv"
      },
      "description": "Exploration: Enrollment by Department",
      "mark": "bar",
      "encoding": {
        "x": {
          "field": "DNO",
          "type": "nominal",
          "title": "Department Number"
        },
        "y": {
          "field": "TotalEnrollment",
          "type": "quantitative",
          "title": "Total Enrollment"
        },
        "color": {
          "condition": {
            "test": "datum.TotalEnrollment > quantiles('TotalEnrollment', 0.90)",
            "value": "red"
          },
          "value": "blue"
        }
      },
      "params": [
        {
          "name": "selectedCourses",
          "select": {
            "type": "point",
            "encodings": [
              "x"
            ]
          }
        }
      ],
      "transform": [
        {
          "filter": {
            "param": "selectedCourses"
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_enrollment_by_day_hour.csv"
      },
      "description": "Detail: Enrollment by Day and Hour",
      "mark": "point",
      "encoding": {
        "x": {
          "field": "Days",
          "type": "nominal",
          "title": "Days of the Week"
        },
        "y": {
          "field": "Hours",
          "type": "quantitative",
          "title": "Course Hours"
        },
        "size": {
          "field": "TotalEnrollment",
          "type": "quantitative",
          "title": "Total Enrollment"
        }
      },
      "interactions": [
        {
          "object": "scatter plot",
          "verb": "zoom&pan",
          "effect": {
            "description": "Zoom into specific days and hours ranges, refining the view for temporal enrollment patterns.",
            "params": []
          }
        }
      ]
    },
    {
      "height": 200,
      "width": 200,
      "data": {
        "url": "http://localhost:8888/vw_enrollment_by_credit.csv"
      },
      "description": "Detail: Enrollment by Credit Hours",
      "mark": "boxplot",
      "encoding": {
        "x": {
          "field": "Credits",
          "type": "quantitative",
          "title": "Credit Hours"
        },
        "y": {
          "field": "TotalEnrollment",
          "type": "quantitative",
          "title": "Total Enrollment"
        },
        "color": {
          "field": "DNO",
          "type": "nominal",
          "title": "Department"
        }
      },
      "interactions": [
        {
          "object": "boxplot",
          "verb": "hover",
          "effect": {
            "description": "Highlight hovered credit-hour ranges, facilitating further exploration of courses and credit-hour influences.",
            "params": []
          }
        }
      ]
    }
  ]
}