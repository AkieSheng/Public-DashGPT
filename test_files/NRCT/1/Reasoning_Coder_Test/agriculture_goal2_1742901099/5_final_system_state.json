  "sqls": [
    {
      "SQL": "CREATE VIEW summary_view AS SELECT cow.District, cow.Season, cp.Yield_quintals, cp.Production_metric_tons FROM crop_production_data AS cp JOIN crop_water_usage_data AS cwp ON cp.District = cwp.District AND cp.Crop = cwp.Crop",
      "corrView": "1",
      "fk": [
        {
          "key": "District",
          "table": "summarized_soil_analytics_view"
        }
      ],
      "id": 1,
      "name": "summary_view",
      "pk": "District, Season"
    },
    {
      "SQL": "CREATE VIEW detail_view AS SELECT cpd.Crop, cpd.District, cpd.Area_hectares, cpd.Yield_quintals, cpd.Production_metric_tons FROM crop_production_data AS cpd",
      "corrView": "5",
      "fk": [
        {
          "key": "District",
          "table": "summary_view"
        }
      ],
      "id": 2,
      "name": "detail_view",
      "pk": "Crop, District"
    },
    {
      "SQL": "CREATE VIEW heat_view AS SELECT cpd.Crop, cpd.District, cpd.Area_hectares, cpd.Yield_quintals, cpd.Production_metric_tons FROM crop_production_data AS cpd",
      "corrView": "3",
      "fk": [
        {
          "key": "District",
          "table": "summary_view"
        }
      ],
      "id": 3,
      "name": "heat_view",
      "pk": "Crop, District"
    },
    {
      "SQL": "CREATE VIEW trend_view AS SELECT cpd.Crop, cpd.District, cpd.Season, yr.Yield_over_Year FROM crop_production_data AS cpd JOIN year_over_year_yield_view AS yr ON cpd.District = yr.District AND cpd.Crop = yr.Crop AND cpd.Season = yr.Season",
      "corrView": "4",
      "fk": [
        {
          "key": "District",
          "table": "summary_view"
        }
      ],
      "id": 4,
      "name": "trend_view",
      "pk": "Crop, District, Year"
    },
    {
      "SQL": "CREATE VIEW anomaly_view AS SELECT cpd.District, cpd.Area_hectares, cpd.Yield_quintals, (cpd.Yield_quintals - AVG(cpd.Yield_quintals) OVER (PARTITION BY cpd.District)) / STDDEV(cpd.Yield_quintals) OVER (PARTITION BY cpd.District) AS Anomaly_score FROM crop_production_data AS cpd",
      "corrView": "5",
      "fk": [
        {
          "key": "District",
          "table": "detail_view"
        }
      ],
      "id": 5,
      "name": "anomaly_view",
      "pk": "District, Area_hectares, Yield_quintals"
    },
    {
      "SQL": "CREATE VIEW summarized_soil_analytics_view AS SELECT District, AVG(pH_Level) AS avg_pH, AVG(Organic_Matter) AS avg_Organic_Matter, AVG(Nitrogen_Content) AS avg_Nitrogen, AVG(Phosphorus_Content) AS avg_Phosphorus, AVG(Potassium_Content) AS avg_Potassium FROM soil_analysis_data GROUP BY District",
      "corrView": "1",
      "fk": [],
      "id": 6,
      "name": "summarized_soil_analytics_view",
      "pk": "District"
    },
    {
      "SQL": "CREATE VIEW year_over_year_yield_view AS SELECT District, Crop, Season, Lag(Production_metric_tons) OVER (PARTITION BY District, Crop ORDER BY CASE WHEN Season = 'Kharif' THEN 1 ELSE 2 END) AS Yield_over_Year FROM crop_production_data",
      "corrView": "4",
      "fk": [
        {
          "key": "District",
          "table": "summary_view"
